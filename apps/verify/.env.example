# Required — base58-encoded 64-byte tweetnacl secret key. Generate via
# `pnpm --filter verify generate-key` and paste the printed secret here
# (and into Vercel production env). The public key is served at
# GET /api/verify/operator-key for downstream verifiers.
NEXUS_VERIFY_OPERATOR_SECRET_KEY=

# Optional — base URL used to fetch the Nexus *receipt* operator key
# when callers don't pass `operatorKey` in the request body.
# Defaults to https://nexus.vdmnexus.com when unset.
NEXUS_DEFAULT_ENDPOINT=
