# VDM Nexus — Mission Control (console) env vars
# Copy to .env.local and fill in your values.

# --- Supabase ---
# Same project as apps/web — vdmnexus-web (ref wuxorxtniyfwjaqurwoe).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only — used by the private /dashboard view.
SUPABASE_SERVICE_ROLE_KEY=

# --- Session signing ---
# Long random string used to HMAC the sign-in challenge + session cookie.
# Generate with: openssl rand -hex 32
CONSOLE_SESSION_SECRET=

# --- Nexus API (referenced in the ERC-8004 card) ---
NEXT_PUBLIC_NEXUS_URL=https://nexus.vdmnexus.com

# --- Feature flags ---
# Gates the entire Mission Control sign-in + dashboard flow. Defaults
# to false — /sign-in and /dashboard render a "Coming Soon" notice
# until the agent-creation step is designed. Flip to "true" only when
# the v1 sign-in flow ships.
NEXT_PUBLIC_CONSOLE_AUTH_ENABLED=false
