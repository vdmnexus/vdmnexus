# --- Required for the API ---
SUPABASE_URL=https://wuxorxtniyfwjaqurwoe.supabase.co
# Accepts either SUPABASE_SERVICE_ROLE_KEY or SUPABASE_SERVICE_KEY.
SUPABASE_SERVICE_ROLE_KEY=
OPENROUTER_API_KEY=
# Documented for completeness; the dev server actually binds via the package.json
# script (`next dev --port 3001`). Override there if you need a different port.
NEXUS_PORT=3001

# --- On-chain deposit detection ---
# Public address agents send USDC to. When NEXUS_KMS_KEY_ID is set, this MUST
# match the Solana address derived from the KMS public key — the facilitator
# asserts this at startup and fails closed on mismatch.
NEXUS_DEPOSIT_ADDRESS=
# Fallback signing key — used only when NEXUS_KMS_KEY_ID is unset. Acceptable
# for local dev; set the KMS env vars below for production.
NEXUS_DEPOSIT_SECRET_KEY=
# Override the default USDC mint if you're using a test token.
# NEXUS_USDC_MINT=
# Secret required to call POST /api/v1/deposits/scan; Vercel Cron will pass it.
CRON_SECRET=
# Optional dedicated RPC endpoint (Helius, Triton, QuickNode...). Falls back
# to public RPC for the chosen network.
SOLANA_RPC_URL=
# How many recent signatures to scan per cron tick.
NEXUS_DEPOSIT_SCAN_LIMIT=50

# --- Optional ---
# Maximum age of a signed inference request (seconds). Older = rejected as replay.
NEXUS_REQUEST_MAX_AGE_SECONDS=60
# Solana network the rail settles on. Devnet for v1; mainnet-beta once on-chain
# topups have been tested end-to-end and the deposit key lives in a real KMS.
SOLANA_NETWORK=devnet

# --- x402-gated /chat/completions ---
# Flat USDC fee charged per request. Real OpenRouter cost is logged separately.
X402_FLAT_PRICE_USDC=0.01
# Hard ceiling on X402_FLAT_PRICE_USDC. The route refuses to advertise a
# challenge (500 server_misconfigured + price.over_cap log) if the configured
# flat price exceeds this cap. Defaults to 0.10 USDC. Keep this tight on
# mainnet so a typo can't authorise an unbounded charge.
NEXUS_MAX_PRICE_USDC=0.10
# Mainnet kill switch. Set to "false" to fail-closed on any mainnet-bound
# request to /v1/chat/completions with 503 + mainnet.disabled log. Devnet,
# Sepolia, and other testnets stay reachable regardless. Default (unset or
# any other value) leaves mainnet enabled. Flip this in Vercel to take the
# rail offline in seconds.
NEXUS_MAINNET_ENABLED=
# Optional operator allowlist. Comma-separated base58 payer pubkeys. When
# set, /v1/chat/completions rejects any payer not on the list with 403 +
# agent.not_allowed log. When unset (default) the allowlist is disabled.
# Useful for the first few days on mainnet — narrow the blast radius to
# known agents before opening to public traffic.
NEXUS_ALLOWED_AGENTS=
# CAIP-2 network identifier returned in the 402 challenge. Falls back to devnet.
# Valid values: "solana:devnet", "solana:mainnet"
X402_NETWORK=solana:devnet
# Wallet that receives x402 payments. Falls back to NEXUS_DEPOSIT_ADDRESS.
X402_RECIPIENT_ADDRESS=
# Mainnet-specific deposit address. When set, requests with body.network="mainnet"
# pay to this address instead of NEXUS_DEPOSIT_ADDRESS. Leave unset to use the
# devnet address for both networks (acceptable since Solana keys are
# network-independent). See docs/ops/mainnet-flip for the full rollout runbook.
NEXUS_MAINNET_DEPOSIT_ADDRESS=
# Facilitator selection. Set EXACTLY ONE of NEXUS_FACILITATOR_LOCAL or
# X402_FACILITATOR_URL in production. Priority order in code:
#   1. NEXUS_FACILITATOR_LOCAL=true → self-hosted in-process facilitator
#      (uses NEXUS_DEPOSIT_SECRET_KEY as the fee-payer keypair)
#   2. X402_FACILITATOR_URL=<url>  → external facilitator over HTTP
#   3. NEXUS_ALLOW_MOCK_FACILITATOR=true → MockFacilitator (dev only)
# If none is set, /api/v1/chat/completions returns 500 server_misconfigured.
NEXUS_FACILITATOR_LOCAL=
X402_FACILITATOR_URL=
# Bearer token sent in Authorization header (required for CDP-style remote facilitators).
X402_FACILITATOR_API_KEY=
# Dev-only escape hatch. "true" + neither LOCAL nor URL set → MockFacilitator
# (accepts ANY payment payload). Production must leave this UNSET.
NEXUS_ALLOW_MOCK_FACILITATOR=

# --- Facilitator signing: KMS-backed (preferred for production) ---
# When NEXUS_KMS_KEY_ID is set AND NEXUS_FACILITATOR_LOCAL=true, the local
# facilitator signs every Solana tx via AWS KMS instead of reading
# NEXUS_DEPOSIT_SECRET_KEY. The KMS key MUST be an Ed25519 asymmetric key
# (KeySpec=ECC_NIST_EDWARDS25519, KeyUsage=SIGN_VERIFY). The IAM principal
# whose access keys are below needs kms:Sign + kms:GetPublicKey +
# kms:DescribeKey scoped to this key.
#
# At startup the facilitator derives the Solana address from KMS.GetPublicKey
# and asserts it matches NEXUS_DEPOSIT_ADDRESS — a mismatch fails-closed.
NEXUS_KMS_KEY_ID=
NEXUS_KMS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Rate limiting (Upstash Redis) ---
# Both vars must be set for rate limiting to be active. If either is missing,
# the limiter fails open and emits a single `rate_limit.unavailable` warn log
# on first request. Provision via the Vercel Marketplace (Upstash Redis, free).
#
# The Vercel Marketplace Upstash integration writes KV_REST_API_URL +
# KV_REST_API_TOKEN (legacy naming, same Upstash backend). Standalone Upstash
# uses UPSTASH_REDIS_REST_URL + UPSTASH_REDIS_REST_TOKEN. Either pair works.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# --- Sponsored grants (POST /api/v1/grants) ---
# Issues a one-time USDC credit to a fresh agent_pubkey so it can make its
# first signed-inference call without buying USDC. Per-pubkey deduped via
# the unique index on agent_grants.agent_pubkey; per-IP deduped by counting
# rows with the same ip_hash; globally capped by NEXUS_GRANT_BUDGET_DAILY_USDC
# (sum of grants per UTC day). IP_HASH_SALT must match the salt used by the
# web app if you want abuse signals to correlate.
NEXUS_GRANT_AMOUNT_USDC=0.10
NEXUS_GRANT_MAX_PER_IP=3
NEXUS_GRANT_BUDGET_DAILY_USDC=5.00
IP_HASH_SALT=

# --- Demo-only ---
NEXUS_ENDPOINT=http://localhost:3001/api/v1
# Base58 64-byte secret key. Leave blank to generate one each run.
DEMO_AGENT_SECRET_KEY=
# How much USDC to seed the demo agent with (manual, no on-chain deposit yet).
DEMO_SEED_USDC=1.00
