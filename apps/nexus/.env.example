# --- Required for the API ---
SUPABASE_URL=https://wuxorxtniyfwjaqurwoe.supabase.co
# Accepts either SUPABASE_SERVICE_ROLE_KEY or SUPABASE_SERVICE_KEY.
SUPABASE_SERVICE_ROLE_KEY=
OPENROUTER_API_KEY=
# Documented for completeness; the dev server actually binds via the package.json
# script (`next dev --port 3001`). Override there if you need a different port.
NEXUS_PORT=3001

# --- On-chain deposit detection ---
# Public address agents send USDC to. Devnet keypair was generated for v1;
# rotate before mainnet behind proper key management.
NEXUS_DEPOSIT_ADDRESS=
NEXUS_DEPOSIT_SECRET_KEY=
# Override the default USDC mint if you're using a test token.
# NEXUS_USDC_MINT=
# Secret required to call POST /api/v1/deposits/scan; Vercel Cron will pass it.
CRON_SECRET=
# Optional dedicated RPC endpoint (Helius, Triton, QuickNode...). Falls back
# to public RPC for the chosen network.
SOLANA_RPC_URL=
# How many recent signatures to scan per cron tick.
NEXUS_DEPOSIT_SCAN_LIMIT=50

# --- Optional ---
# Maximum age of a signed inference request (seconds). Older = rejected as replay.
NEXUS_REQUEST_MAX_AGE_SECONDS=60
# Solana network the rail settles on. Devnet for v1; mainnet-beta once on-chain
# topups have been tested end-to-end and the deposit key lives in a real KMS.
SOLANA_NETWORK=devnet

# --- x402-gated /chat/completions (day 1 scaffolding) ---
# Flat USDC fee charged per request. Real OpenRouter cost is logged separately.
X402_FLAT_PRICE_USDC=0.01
# Solana network identifier returned in the 402 challenge. Falls back to devnet.
X402_NETWORK=solana-devnet
# Wallet that receives x402 payments. Falls back to NEXUS_DEPOSIT_ADDRESS.
X402_RECIPIENT_ADDRESS=
# Facilitator URL. Leave blank during day 1 scaffolding → mock facilitator.
# Set to the Coinbase CDP endpoint (or self-hosted) for real Solana settlement.
X402_FACILITATOR_URL=
X402_FACILITATOR_API_KEY=

# --- Demo-only ---
NEXUS_ENDPOINT=http://localhost:3001/api/v1
# Base58 64-byte secret key. Leave blank to generate one each run.
DEMO_AGENT_SECRET_KEY=
# How much USDC to seed the demo agent with (manual, no on-chain deposit yet).
DEMO_SEED_USDC=1.00
