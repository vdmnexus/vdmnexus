# VDM Nexus marketing site env vars
# Copy to .env.local and fill in your values.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only — used by waitlist/roadmap/buildlog/receipts API routes.
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin gate ---
# Protects /admin/* and admin write endpoints. Also accepted via X-Admin-Secret
# header for tooling.
ADMIN_PASSWORD=

# --- Waitlist + abuse signals ---
# Salt for hashing client IP before storing on waitlist rows. Must match the
# nexus app's IP_HASH_SALT if you want grant + waitlist abuse signals to
# correlate.
IP_HASH_SALT=

# --- Notifications (all optional) ---
# Resend transactional email — fired fire-and-forget on waitlist signup.
RESEND_API_KEY=
RESEND_FROM=                          # e.g. hello@vdmnexus.com
# Slack incoming webhook — internal notification on waitlist signup.
SLACK_WEBHOOK_URL=

# --- Token launch gate ---
# Defaults to false (fail-closed) — /token and /whitepaper return 404 and are
# absent from nav/footer/robots until this is "true". Flip on Vercel only when
# the token is live and legal sign-off is in.
NEXT_PUBLIC_LAUNCH_LIVE=false

# --- Polymarket public-dashboard gate ---
# Defaults to false (fail-closed) — /agents/predictions returns 404 and is
# absent from nav/robots until this is "true". The Polymarket agent runs
# privately under /admin/predictions either way; this flag only controls the
# public surface. Flip on Vercel only after the Spanish-counsel memo on
# RD 958/2020 art. 23.1.b (gambling-promotion) returns favourably. See
# agents/polymarket/README.md.
NEXT_PUBLIC_POLYMARKET_PUBLIC=false

# --- Nexus API endpoints (consumed by /playground and /api/playground/*) ---
# Public Nexus base URL surfaced to client code. Defaults to production.
NEXT_PUBLIC_NEXUS_URL=
# Server-side URL the playground API routes call. Defaults to
# https://nexus.vdmnexus.com/api/v1.
NEXUS_INFERENCE_URL=

# --- Playground sponsored grant ---
# Base58 64-byte secret of the agent that signs the sponsored credit on
# behalf of fresh /playground visitors. Must have a funded balance on the
# nexus rail.
PLAYGROUND_AGENT_SECRET_KEY=

# --- Base/EVM agent registration ---
# Optional deposit address advertised in /.well-known/agent-registration.json
# for the Base (EVM) network. Leave blank to omit Base from the agent card.
BASE_DEPOSIT_ADDRESS=

# Required Supabase schema:
#
# create table waitlist (
#   id uuid primary key default gen_random_uuid(),
#   email text not null unique,
#   building text,
#   created_at timestamptz default now()
# );
#
# alter table waitlist enable row level security;
# create policy "anon can insert waitlist"
#   on waitlist for insert to anon with check (true);
