# ---------- Required ----------
# Nexus agent Ed25519 secret key (base58, 64 bytes). This is the agent
# *identity* — every reasoning call to nexus.vdmnexus.com is signed with
# this key and a USDC payment is settled per call.
POLYMARKET_AGENT_SECRET_KEY=

# Polygon EOA private key holding USDC for placing Polymarket bets.
# This is the *betting* wallet — separate from the Nexus identity.
# KYC must be completed at https://polymarket.com developer portal.
POLYGON_PRIVATE_KEY=

# Supabase service role — writes to public.polymarket_bets.
SUPABASE_URL=https://wuxorxtniyfwjaqurwoe.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret for the Vercel-Cron → agent webhook (HMAC). Set the
# same value in apps/web env as POLYMARKET_AGENT_WEBHOOK_SECRET.
WEBHOOK_SECRET=

# ---------- Nexus rail ----------
NEXUS_ENDPOINT=https://nexus.vdmnexus.com/api/v1
NEXUS_NETWORK=solana:mainnet
# OpenRouter model slug used for the reasoning call.
REASONING_MODEL=anthropic/claude-sonnet-4

# ---------- Polymarket ----------
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
# Set to "1" to run end-to-end without submitting orders (writes bet rows
# with status='failed' and failure_reason='dry_run').
POLYMARKET_DRY_RUN=0

# ---------- Hard caps (defaults match in-code; env overrides) ----------
MAX_BET_USDC=50
MAX_BETS_PER_DAY=5
MAX_BANKROLL_FRACTION=0.30
MIN_CONFIDENCE=0.60
MIN_MARKET_VOLUME_USDC=10000
MIN_TIME_TO_CLOSE_HOURS=24
DRAWDOWN_PAUSE_PCT=0.30

# ---------- Targeted categories (comma-separated) ----------
POLYMARKET_CATEGORIES=politics,economics

# ---------- Optional ----------
# Sends a single message on drawdown auto-pause. If unset, alerts log
# only.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional NewsAPI key for context enrichment. If unset, the agent
# reasons from the market description + current price alone.
NEWSAPI_KEY=
