{
  "name": "@vdm-nexus/mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for VDM Nexus signed inference. Plug into Claude Desktop, Cursor, or any MCP-aware client.",
  "license": "MIT",
  "author": "VDM Nexus",
  "homepage": "https://vdmnexus.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vdmnexus/vdmnexus.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/vdmnexus/vdmnexus/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "cursor",
    "ai-agents",
    "solana",
    "x402",
    "signed-inference",
    "vdmnexus"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "vdm-nexus-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "tsc && chmod +x dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vdm-nexus/sdk": "workspace:*",
    "@vdm-nexus/x402": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5"
  }
}
