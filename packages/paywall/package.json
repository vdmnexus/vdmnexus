{
  "name": "@vdm-nexus/paywall",
  "version": "0.1.0",
  "description": "Drop-in x402 paywall for Express, Hono, and Next.js. Every paid call returns a signed Ed25519 receipt of what your handler produced.",
  "license": "MIT",
  "author": "VDM Nexus",
  "homepage": "https://vdmnexus.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vdmnexus/vdmnexus.git",
    "directory": "packages/paywall"
  },
  "bugs": {
    "url": "https://github.com/vdmnexus/vdmnexus/issues"
  },
  "keywords": [
    "x402",
    "paywall",
    "solana",
    "usdc",
    "ai-agents",
    "ed25519",
    "signed-inference",
    "express",
    "hono",
    "nextjs",
    "vdmnexus"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/adapters/express.d.ts",
      "import": "./dist/adapters/express.js",
      "default": "./dist/adapters/express.js"
    },
    "./hono": {
      "types": "./dist/adapters/hono.d.ts",
      "import": "./dist/adapters/hono.js",
      "default": "./dist/adapters/hono.js"
    },
    "./next": {
      "types": "./dist/adapters/next.d.ts",
      "import": "./dist/adapters/next.js",
      "default": "./dist/adapters/next.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test --import tsx/esm src/__tests__/*.test.ts",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@vdm-nexus/sdk": "workspace:*",
    "@x402/core": "^2.12.0",
    "@x402/svm": "^2.12.0",
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3"
  },
  "peerDependencies": {
    "express": "^4 || ^5",
    "hono": "^3 || ^4",
    "next": "^14 || ^15"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true },
    "hono": { "optional": true },
    "next": { "optional": true }
  },
  "devDependencies": {
    "@types/express": "^5",
    "@types/node": "^22",
    "express": "^5",
    "hono": "^4",
    "next": "^15",
    "react": "^19",
    "tsx": "^4",
    "typescript": "^5"
  }
}
