{
  "name": "@vdm-nexus/sdk",
  "version": "0.2.0",
  "description": "Open-source SDK for VDM Nexus — autonomous AI agents that authenticate and pay for compute with a Solana keypair. No API keys.",
  "license": "MIT",
  "author": "VDM Nexus",
  "homepage": "https://vdmnexus.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vdmnexus/vdmnexus.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/vdmnexus/vdmnexus/issues"
  },
  "keywords": [
    "solana",
    "ai",
    "ai-agents",
    "autonomous-agents",
    "llm",
    "inference",
    "ed25519",
    "usdc",
    "compute",
    "vdmnexus"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test --import tsx/esm src/__tests__/*.test.ts",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5"
  }
}
